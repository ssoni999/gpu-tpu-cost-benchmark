# Copy to gpu.env and fill in before running on GCE (do not commit gpu.env).
export PROJECT_ID=your-project-id
export ZONE=us-central1-a
export VM_NAME="${USER}-g4-qwen3-4b"

# On-demand $/hour — replace with your actual G4 rate.
export GPU_ACCELERATOR_HOURLY_USD=0.70
export GPU_VM_HOURLY_USD=0.15

export HF_TOKEN=your-huggingface-token
