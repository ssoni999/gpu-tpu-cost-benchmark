# Copy to tpu.env and fill in before running on TPU VM (do not commit tpu.env).
export PROJECT_ID=your-project-id
export ZONE=us-central1-a
export TPU_NAME="${USER}-v5e-qwen3-4b"
export QR_ID="${USER}-v5e-qr"

# v5e single-chip (Qwen3-4B)
export TPU_ACCELERATOR_TYPE=v5litepod-1
export TPU_RUNTIME_VERSION=v2-alpha-tpuv5-lite

# On-demand $/hour — replace with current Cloud TPU v5e pricing.
export TPU_ACCELERATOR_HOURLY_USD=1.20
export TPU_VM_HOURLY_USD=0.0

export HF_TOKEN=your-huggingface-token
